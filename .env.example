# Ejemplo de archivo de entorno para UFPS Superset
# Copia este archivo a `.env` y reemplaza valores sensibles antes de ejecutar.

# Indicar si se deben cargar los ejemplos al iniciar Superset (yes / no)
SUPERSET_LOAD_EXAMPLES=yes

# Clave secreta para Flask/Superset - reemplaza por un valor seguro
SUPERSET_SECRET_KEY=change_me_to_a_secure_random_value

# MySQL (contenedor `db` en docker-compose.yml)
# Nota: el contenedor expone el puerto 3306 internamente y mapea al host 33061
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=superset
MYSQL_USER=superset
MYSQL_PASSWORD=change_me_superset_db_password

# Ejemplo de uso:
# cp .env.example .env
# Edita .env y luego: docker compose up -d --build
